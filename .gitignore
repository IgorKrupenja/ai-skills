.env
.playwright-mcp/
# Ignore local Claude Code state, but DO commit the skill symlinks so cloud
# sessions auto-load <repo>/.claude/skills/ (see cloud/sync-skills.sh).
.claude/*
!.claude/skills/

# spotify cached user token (contains a refresh token)
.spotify_token.json

# Symlinked skills that live in other repos (machine-specific targets)
events-add
events-coda
events-crawl

# new-life local state (added / declined / banned-series — personal, never published)
new-life/state.json