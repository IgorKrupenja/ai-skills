# lhv-investment-report
LHV_USERNAME="john.smith"
LHV_ISIKUKOOD="38001010000"
LHV_ACCOUNT_INVESTMENT="EE061700017000123456"
LHV_ACCOUNT_EXTERNAL="LT123456789012345678"

# linkedin-connect
LINKEDIN_CONNECT_URL="https://www.linkedin.com/search/results/people/?geoUrn=%5B%22102974008%22%5D&keywords=HR%20OR(%22Talent%20acquisition%22)%20Sourcer%20OR(%22IT%20Recruiter%22)%20OR(%22Tech%20Recruiter%22)%20OR(%22technical%20recruiter%22)%20OR(%22Talent%20Sourcer%22)%20OR%20recruiter&network=%5B%22S%22%2C%22O%22%5D"

# linkedin-grow
