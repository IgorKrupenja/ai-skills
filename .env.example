# spotify
SPOTIFY_CLIENT_ID="0123456789abcdef0123456789abcdef"
SPOTIFY_CLIENT_SECRET="fedcba9876543210fedcba9876543210"
SPOTIFY_REDIRECT_URI="http://127.0.0.1:8888/callback"
SPOTIFY_PLAYLIST_ID="37i9dQZF1DXcBWIGoYBM5M"
# Optional named playlists — each SPOTIFY_PLAYLIST_<NAME> is usable as `--playlist <name>`
SPOTIFY_PLAYLIST_CLASSICS="0000000000000000000000"
SPOTIFY_PLAYLIST_SPORT="1111111111111111111111"
# Obtained once via `python3 spotify.py auth` (it prints REFRESH_TOKEN). Leave blank to bootstrap.
SPOTIFY_REFRESH_TOKEN=""

# new-life
BOOKMARKS_FILE="$HOME/Library/Application Support/Vivaldi/Default/Bookmarks"  # Chromium-format bookmarks JSON
NEW_LIFE_BOOKMARKS_FOLDER="New Life/Events"   # folder path inside bookmarks, /-separated
NEW_LIFE_CALENDAR_ID="xxxxxxxxxxxxxxxx@group.calendar.google.com"  # create via: gog calendar create-calendar "New Life"
NEW_LIFE_EVENT_COLOR="6"                       # gog event color id 1-11 (6 = Tangerine); see: gog calendar colors
NEW_LIFE_TIMEZONE="Europe/Tallinn"
